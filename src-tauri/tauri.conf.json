{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/tauri-v2.4.0/crates/tauri-cli/config.schema.json",
  "productName": "Gemma 4 E4B",
  "version": "0.1.0",
  "identifier": "com.manu.gemma",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "enableGTKAppId": false,
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Gemma 4 E4B",
        "width": 900,
        "height": 650,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "entitlements": "./entitlements.plist"
    }
  },
  "plugins": {}
}
